{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "labels": ["dependencies"],
  "dependencyDashboard": false,
  "rebaseWhen": "behind-base-branch",
  "prHourlyLimit": 0,
  "packageRules": [
    {
      "description": "Keep .gitlab-ci.yml include refs SHA-pinned to main via the custom regex manager; disable the built-in gitlabci-include manager so it never proposes tag bumps (e.g. v0.0.48) for security.",
      "matchManagers": ["gitlabci-include"],
      "enabled": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["\\.tf$"],
      "matchStrings": [
        "source\\s*=\\s*\"git::(?<depName>https?://[^?\"]+?/terraform-modules)\\.git(?://[^?\"]*)?\\?ref=(?<currentDigest>[a-f0-9]{40})\""
      ],
      "datasourceTemplate": "git-refs",
      "currentValueTemplate": "main"
    },
    {
      "customType": "regex",
      "fileMatch": ["(^|/)\\.gitlab-ci\\.ya?ml$"],
      "matchStrings": [
        "project:\\s*['\"]?(?<project>tnoff-projects/[^'\"\\s]+)['\"]?[\\s\\S]{0,200}?ref:\\s*['\"]?(?<currentDigest>[a-f0-9]{40})['\"]?"
      ],
      "depNameTemplate": "https://gitlab.com/{{{project}}}",
      "datasourceTemplate": "git-refs",
      "currentValueTemplate": "main"
    }
  ]
}
